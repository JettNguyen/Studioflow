{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace @studioflow/shared && npm run build --workspace @studioflow/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://studioflow-api-pi.vercel.app/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://studioflow-api-pi.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
